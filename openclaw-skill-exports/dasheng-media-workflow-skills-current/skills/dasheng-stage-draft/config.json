{
  "name": "dasheng-stage-draft",
  "version": "1.0.0",
  "description": "Stage 3 Draft - 初稿生成（标准基线稿）",
  "stage": "draft",
  "stage_number": 3,
  "runner": "node",
  "entry": "index.js",
  "upstream_gate": "selected_topics.json",
  "output_gate": "final_structure_snapshot.json",
  "hitl": true,
  "trigger": "manual",
  "dependencies": {
    "python": ">=3.10",
    "node": ">=18.0.0"
  },
  "inputs": {
    "required": [
      "selected_topics.json"
    ],
    "optional": [
      "topic_cards.json"
    ]
  },
  "outputs": {
    "documents": [
      "03_ReasoningSheet_<topic>.md",
      "03_标准初稿_<topic>.md",
      "03_初稿_报告.md"
    ],
    "manifests": [
      "draft_manifest.json",
      "final_structure_snapshot.json"
    ],
    "gates": [
      "final_structure_snapshot.json"
    ]
  },
  "quality_requirements": {
    "structure_limit": "3-4 top-level sections maximum",
    "traceability": "Every claim must trace to external source",
    "no_internal_stats": "Never include intake statistics in article content",
    "baseline_only": "No style DNA injection, no channel customization"
  }
}
