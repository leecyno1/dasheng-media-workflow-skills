# 大圣自媒体工作流 - 环境变量模板
# 复制此文件为 .env 并根据实际情况修改

# ========== 核心路径配置 ==========
# 项目根目录（默认使用当前工作目录）
DASHENG_ROOT=.

# 产物输出根目录
DASHENG_OUTPUT_ROOT=${DASHENG_ROOT}/产物

# ========== AI API 配置 ==========
# Anthropic API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ========== 飞书配置 ==========
# 飞书 App ID
FEISHU_APP_ID=your-feishu-app-id

# 飞书 App Secret
FEISHU_APP_SECRET=your-feishu-app-secret

# 飞书文档Token（可选）
FEISHU_DOC_TOKEN=

# ========== 外部依赖路径 ==========
# OpenClaw 安装路径
OPENCLAW_ROOT=~/.openclaw

# Bun 二进制路径
BUN_BINARY=~/.bun/bin/bun

# baoyu-imagine skill 脚本路径
BAOYU_IMAGINE_SCRIPT=~/.codex/skills/baoyu-imagine/scripts/main.ts

# Remotion 项目目录（视频渲染用）
DASHENG_REMOTION_PROJECT=~/clawd/remotion-video-starter

# 飞书 SDK 路径
OPENCLAW_FEISHU_SDK_PATH=~/.npm-global/lib/node_modules/openclaw/dist/extensions/feishu/node_modules/@larksuiteoapi/node-sdk

# 飞书配置文件
DASHENG_FEISHU_CONFIG=~/clawd/configs/feishu_api.conf

# ========== 外部服务配置 ==========
# 微信公众号 Cookie（用于内容采集）
WECHAT_COOKIE=your-wechat-cookie-here

# Minimax API Token
MINIMAX_API_TOKEN=your-minimax-token-here

# 知识库 API
KNOWLEDGE_BASE_API=your-knowledge-base-api-here

# ========== 平台配置 ==========
# 目标平台（逗号分隔：wechat,xhs,weibo,douyin）
TARGET_PLATFORMS=wechat,xhs

# ========== 测试配置 ==========
# 使用模拟响应进行测试（不调用真实 AI）
DASHENG_USE_MOCK_RESPONSE=false

# Mock 响应文件路径
DASHENG_DRAFT_FAKE_RESPONSE_FILE=${DASHENG_ROOT}/tests/fixtures/fake_draft_response.json

# ========== 调试配置 ==========
# 启用调试模式
DEBUG=false

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO