# Environment Variables Configuration Template
# Copy relevant sections to your shell profile (~/.zshrc or ~/.bashrc)

# ============================================================
# Core Path Configuration
# ============================================================

# Project root directory (default: /Volumes/PSSD/Projects/公众号文章)
export DASHENG_PROJECT_ROOT="/Volumes/PSSD/Projects/公众号文章"

# Desktop delivery directory (default: ~/Desktop/自媒体创作)
export DASHENG_DESKTOP_ROOT="$HOME/Desktop/自媒体创作"

# ============================================================
# Feishu Configuration
# ============================================================

# Feishu API config file (default: ~/clawd/configs/feishu_api.conf)
export DASHENG_FEISHU_CONFIG="$HOME/clawd/configs/feishu_api.conf"

# Feishu Bot config (default: {PROJECT_ROOT}/configs/feishu/liweis_bot_config.json)
export DASHENG_FEISHU_BOT_CONFIG="$DASHENG_PROJECT_ROOT/configs/feishu/liweis_bot_config.json"

# Feishu Stage Contract (default: {PROJECT_ROOT}/configs/feishu/stage_review_contract.json)
export DASHENG_FEISHU_STAGE_CONTRACT="$DASHENG_PROJECT_ROOT/configs/feishu/stage_review_contract.json"

# ============================================================
# Intake Data Sources
# ============================================================

# Port 5173 base URL (default: http://127.0.0.1:18000)
export DASHENG_INTAKE_5173_BASE="http://127.0.0.1:18000"

# Reports base URL (default: http://45.197.148.64:8080)
export DASHENG_INTAKE_REPORTS_BASE="http://45.197.148.64:8080"

# Reports fallback URL (optional)
export DASHENG_INTAKE_REPORTS_FALLBACK=""

# Port 8000 base URL (default: http://45.197.148.64:8000)
export DASHENG_INTAKE_8000_BASE="http://45.197.148.64:8000"

# ============================================================
# WeChat Fetch Configuration
# ============================================================

# Number of retry rounds for WeChat fetch (default: 3)
export DASHENG_WECHAT_FETCH_ROUNDS=3

# Wait time between retries in seconds (default: 8)
export DASHENG_WECHAT_WAIT_SECONDS=8

# Minimum valid items required (default: 8)
export DASHENG_WECHAT_MIN_VALID_ITEMS=8

# ============================================================
# Material Stage Control Flags
# ============================================================

# Enable news screenshot generation (default: 1)
export MATERIAL_ENABLE_NEWS_SCREENSHOT=1

# Skip video probe for faster processing (default: 1)
export MATERIAL_SKIP_VIDEO_PROBE=1

# Stop after first successful AI image generation (default: 1)
export MATERIAL_AI_STOP_AFTER_FIRST_SUCCESS=1

# ============================================================
# Financial Data (Tushare)
# ============================================================

# Tushare token (also read from .tushare_token file)
export TUSHARE_TOKEN="your_tushare_token_here"
export TS_TOKEN="your_tushare_token_here"  # alias

# ============================================================
# Testing / CI
# ============================================================

# Inject fake AI response for tests (file path)
# export DASHENG_DRAFT_FAKE_RESPONSE_FILE="/path/to/fake_response.json"

# Inject fake AI response for tests (inline JSON)
# export DASHENG_DRAFT_FAKE_RESPONSE='{"content": "fake draft content"}'

# ============================================================
# Matplotlib (for headless servers)
# ============================================================

export MPLBACKEND=Agg

# ============================================================
# Image Generation Providers
# ============================================================
# Note: These are typically stored in configs/image_generation/providers.local.env
# Only set here if you need to override the file-based configuration

# export VIVIAI_IMAGE_API_KEY="your_key"
# export VECTORENGINE_API_KEY="your_key"
# export QHAIGC_API_KEY="your_key"
# export GITEE_AI_API_KEY="your_key"

# ============================================================
# Usage Instructions
# ============================================================
# 1. Copy relevant sections to your shell profile (~/.zshrc or ~/.bashrc)
# 2. Replace placeholder values with your actual configuration
# 3. Run: source ~/.zshrc (or source ~/.bashrc)
# 4. Verify: python3 scripts/path_config.py
