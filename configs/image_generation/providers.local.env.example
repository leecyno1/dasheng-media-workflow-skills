# Primary live provider: VectorEngine Gemini generateContent
VECTORENGINE_BASE_URL=https://api.vectorengine.ai
VECTORENGINE_MODEL=gemini-3.1-flash-image-preview
VECTORENGINE_API_KEY=<REPLACE_ME>

# Optional fallback 1: 启航AI OpenAI-compatible images API
QHAIGC_BASE_URL=https://api.qhaigc.net
QHAIGC_API_KEY=<REPLACE_ME>
QHAIGC_IMAGE_MODEL=seedream-5
QHAIGC_IMAGE_FALLBACK_MODEL=seedream-4.6
QHAIGC_CHAT_IMAGE_MODEL=gemini-2.5-flash-image

# Optional fallback 2: 模力方舟 OpenAI-compatible images API
GITEE_AI_BASE_URL=https://ai.gitee.com
GITEE_AI_API_KEY=<REPLACE_ME>
GITEE_QWEN_IMAGE_MODEL=Qwen-Image
GITEE_GLM_IMAGE_MODEL=GLM-Image

# Existing fallback runtime
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_API_KEY=<REPLACE_ME>

# Optional fallback 3: VectorEngine OpenAI-compatible images API
VECTORENGINE_IMAGES_BASE_URL=https://api.vectorengine.ai/v1/images/generations
VECTORENGINE_IMAGES_API_KEY=<REPLACE_ME>
VECTORENGINE_IMAGES_MODEL=doubao-seedream-5-0-260128
