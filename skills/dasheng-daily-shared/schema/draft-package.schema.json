{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dasheng-daily/draft-package.schema.json",
  "title": "DraftPackage",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta",
    "topic_id",
    "title",
    "style",
    "content",
    "word_count"
  ],
  "properties": {
    "meta": {
      "$ref": "./base-meta.schema.json"
    },
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "style": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "word_count": {
      "type": "number"
    },
    "sections_used": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "draft_notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
