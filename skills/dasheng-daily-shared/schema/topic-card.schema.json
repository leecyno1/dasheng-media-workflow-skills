{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dasheng-daily/topic-card.schema.json",
  "title": "TopicCard",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta",
    "topic_id",
    "title",
    "core_thesis",
    "scorecard",
    "proof_requirements"
  ],
  "properties": {
    "meta": {
      "$ref": "./base-meta.schema.json"
    },
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "core_thesis": {
      "type": "string"
    },
    "one_line_judgment": {
      "type": "string"
    },
    "counterintuitive_angle": {
      "type": [
        "string",
        "null"
      ]
    },
    "why_now": {
      "type": "string"
    },
    "reader_value": {
      "type": "string"
    },
    "proof_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "existing_evidence": {
      "type": "array",
      "items": {
        "$ref": "./evidence-item.schema.json"
      },
      "default": []
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "chart_needs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "image_needs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "video_needs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "priority_people": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "priority_orgs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "priority_news_queries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "scorecard": {
      "type": "object",
      "required": [
        "heat",
        "sharpness",
        "evidence",
        "longevity",
        "reader_value",
        "composite"
      ],
      "properties": {
        "heat": {
          "type": "number"
        },
        "sharpness": {
          "type": "number"
        },
        "evidence": {
          "type": "number"
        },
        "longevity": {
          "type": "number"
        },
        "reader_value": {
          "type": "number"
        },
        "composite": {
          "type": "number"
        }
      }
    }
  }
}
