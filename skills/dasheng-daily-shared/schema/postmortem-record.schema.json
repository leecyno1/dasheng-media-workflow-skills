{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dasheng-daily/postmortem-record.schema.json",
  "title": "PostmortemRecord",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta",
    "topic_id",
    "title",
    "performance",
    "scoring_accuracy",
    "insights",
    "recommendations"
  ],
  "properties": {
    "meta": {
      "$ref": "./base-meta.schema.json"
    },
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "performance": {
      "type": "object",
      "additionalProperties": true
    },
    "scoring_accuracy": {
      "type": "object",
      "additionalProperties": true
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
