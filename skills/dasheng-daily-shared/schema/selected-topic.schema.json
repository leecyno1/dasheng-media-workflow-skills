{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dasheng-daily/selected-topic.schema.json",
  "title": "SelectedTopic",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta",
    "topic_id",
    "title",
    "selection_reason"
  ],
  "properties": {
    "meta": {
      "$ref": "./base-meta.schema.json"
    },
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "selection_reason": {
      "type": "string"
    },
    "editor_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "priority": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
