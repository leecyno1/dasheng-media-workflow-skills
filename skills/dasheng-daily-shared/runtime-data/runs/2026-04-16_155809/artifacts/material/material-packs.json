    "claim_bindings": [
      {
        "claim_id": "claim-01",
        "section_id": "section-02",
        "statement": "日本拥有约47吨分离钚，足以制造6000枚核弹头，这些钚主要来自核电站乏燃料后处理，构成潜在核武器原料库。",
        "counterpoint": "钚虽为核武器原料，但是否转化为武器取决于政治意愿和国际压力。",
        "missing_proof": [
          "IAEA关于日本钚库存的最新报告"
        ],
        "chart_need": true
      },
      {
        "claim_id": "claim-02",
        "section_id": "section-02",
        "statement": "近年来日本通过安保法案及提出反击能力概念，实质突破了和平宪法第九条中战争权和专守防卫的限制。",
        "counterpoint": "修宪尚未完成，部分法律仍有争议，实际军事运用仍受制约。",
        "missing_proof": [
          "日本防卫白皮书2025完整版",
          "日本修宪进程的国会辩论记录"
        ],
        "chart_need": null
      },
      {
        "claim_id": "claim-03",
        "section_id": "section-02",
        "statement": "美国战略收缩背景下，日本防卫预算大幅增长，反映其承担更多防务责任以应对中国崛起。",
        "counterpoint": "预算增长不完全等同于军事化，部分资金用于防御性装备和技术升级。",
        "missing_proof": [
          "日本财务省防卫预算历年数据",
          "东亚各国防卫预算对比数据"
        ],
        "chart_need": true
      },
      {
        "claim_id": "claim-04",
        "section_id": "section-03",
        "statement": "从宪法约束、政策、防卫理念到民意基础，日本经历了从严格和平体系向军事化的系统性转变。",
        "counterpoint": "社会内部仍存在反战力量，军事化进程并非全盘接受，存在一定阻力。",
        "missing_proof": [],
        "chart_need": true
      },
      {
        "claim_id": "claim-05",
        "section_id": "section-04",
        "statement": "日本核能力披露激活历史创伤记忆，引发中韩警惕，推动东亚军备竞赛加剧，并威胁全球核不扩散体系。",
        "counterpoint": "具体反应和政策调整仍在演变中，风险存在不确定性。",
        "missing_proof": [
          "中韩官方对日本核能力的正式声明"
        ],
        "chart_need": true
