{
  "name": "dasheng-daily-intake",
  "version": "4.1.0",
  "description": "Stage 1 Intake - 大圣自媒体工作流的 Intake 环节：执行 canonical Stage 1 采集",
  "stage": "intake",
  "stage_number": 1,
  "runner": "python",
  "upstream_gate": null,
  "output_gate": "intake_manifest.json",
  "hitl": false,
  "trigger": {
    "cron": "0 10 * * *",
    "keyword": "daily intake"
  },
  "aliases": [
    "intake",
    "caiji",
    "dasheng-caiji",
    "大圣采集",
    "第一环节"
  ],
  "dependencies": {
    "python": ">=3.10",
    "packages": ["requests", "beautifulsoup4"]
  },
  "inputs": {
    "required": [],
    "optional": []
  },
  "outputs": {
    "documents": [
      "notes/01_内容采集_报告.md",
      "notes/01_内容采集_底稿.md"
    ],
    "manifests": [
      "intake_manifest.json",
      "raw/intake_records.json",
      "entity_rankings.json",
      "event_clusters.json",
      "channel_top10.json",
      "brief_input.json"
    ],
    "gates": [
      "intake_manifest.json"
    ]
  },
  "quality_requirements": {
    "real_titles_only": true,
    "real_links_only": true,
    "wechat_min_valid_items": 8
  },
  "metadata": {
    "runner": {
      "script": "${OPENCLAW_WORKSPACE}/scripts/run_stage1_intake.py",
      "stage_root": "${OPENCLAW_WORKSPACE}/产物/01_内容采集",
      "manifest": "intake_manifest.json"
    },
    "data_sources": [
      "5173",
      "reports",
      "8000-public-wechat",
      "reddit-rss",
      "hacker-news",
      "ai-hot-aggregate",
      "trendradar"
    ],
    "output": {
      "stage_dir": "${OPENCLAW_WORKSPACE}/产物/01_内容采集/{run_id}",
      "report": "notes/01_内容采集_报告.md",
      "draft": "notes/01_内容采集_底稿.md",
      "records": "raw/intake_records.json",
      "handoff": [
        "ai_hot_topics.json",
        "channel_top10.json",
        "event_clusters.json",
        "brief_input.json",
        "intake_manifest.json"
      ]
    },
    "requirements": {
      "real_titles_only": true,
      "real_links_only": true,
      "x_wb_quota": 100,
      "other_platform_quota": 50,
      "wechat_slow_source": true,
      "ai_hot_topics_limit": 10,
      "ai_hot_priority_bias": "high"
    }
  }
}
